<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SelfHelp.StatisticsPage"
             Title="Practice Statistics">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="📊 Practice Statistics"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>


        <!-- History List -->
            <ListView x:Name="SessionListView" ItemsSource="{Binding FilteredSessions}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                                <Label Text="{Binding Date, StringFormat='{0:dd-MMM-yy}'}" Grid.Column="0" FontSize="16"/>
                            <Label Text="{Binding PracticeName}" Grid.Column="1" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding DurationMinutes, StringFormat='{0} min'}" Grid.Column="2" FontSize="16"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
    </ScrollView>
</ContentPage>
