<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SelfHelp.PracticePlayerPage"
             Title="PracticePlayerPage">
    <VerticalStackLayout Padding="20" Spacing="10">
    <Label x:Name="PlaylistTitle"
       Text="Playlist Name"
       FontSize="22"
       FontAttributes="Bold"
       HorizontalOptions="Center" />
        <Label x:Name="PracticeTitle"
           FontSize="22"
           FontAttributes="Bold"
           HorizontalOptions="Center"/>

        <Label Text="Now Playing"
           FontAttributes="Bold"/>

        <Label x:Name="NowPlayingLabel"
           FontSize="18"/>

        <Label x:Name="TotalTimeLabel"/>
        <Label x:Name="ElapsedTimeLabel"/>
        <Label x:Name="TempTimeLabel" />

        <Label x:Name="CurrentItemTotalLabel"/>
        <Label x:Name="CurrentItemElapsedLabel"/>

        <Slider x:Name="ProgressSlider"
            Minimum="0"
            Maximum="1"/>

        <HorizontalStackLayout Spacing="20">

            <Button x:Name="PlayButton"
                Text="Play"
                Clicked="OnPlayClicked"/>

            <Button x:Name="StopButton"  Text="⏹ Stop"  Clicked="OnStopClicked" IsEnabled="False" />

        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>